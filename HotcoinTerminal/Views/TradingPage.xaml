<Page
    x:Class="HotcoinTerminal.Views.TradingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Border Style="{StaticResource GlassPanel}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" MaxWidth="520">
            <TextBlock Text="Торговля" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="13.5"
                       Foreground="{StaticResource TextSecondaryBrush}">
                Вкладка в разработке. Здесь будут: плашки открытых и закрытых сделок,
                общая оценка активов, баланс, P&amp;L и управление позициями.
            </TextBlock>
        </StackPanel>
    </Border>
</Page>
