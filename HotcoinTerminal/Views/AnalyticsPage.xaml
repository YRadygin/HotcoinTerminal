<Page
    x:Class="HotcoinTerminal.Views.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HotcoinTerminal.Controls"
    xmlns:models="using:HotcoinTerminal.Models"
    Background="Transparent">

    <Grid ColumnSpacing="12" RowSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="384" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="348" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- ================= ЛЕВАЯ ПАНЕЛЬ: СКРИНЕР ================= -->
        <Border Grid.Column="0" Grid.RowSpan="2" Style="{StaticResource GlassPanel}">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Grid Grid.Row="0">
                    <StackPanel>
                        <TextBlock Text="Скринер" Style="{StaticResource PanelTitle}" />
                        <TextBlock x:Name="ScreenerStatus" Text="Загрузка данных с Hotcoin…" Style="{StaticResource CaptionText}" Margin="0,2,0,0" />
                        <TextBlock Text="128 пар · обновлено 14:32 (заглушка)"
                                   Style="{StaticResource CaptionText}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            CornerRadius="14" Width="36" Height="30" Padding="0"
                            Content="&#x21bb;" Click="OnRefreshClick" />
                </Grid>

                <!-- Чипы стратегий -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                    <ToggleButton Content="Grid" Tag="Grid" IsChecked="True"
                                  Style="{StaticResource ChipToggle}" Click="OnStrategyChipClick" />
                    <ToggleButton Content="Mean Rev" Tag="Mean Rev" IsChecked="True"
                                  Style="{StaticResource ChipToggle}" Click="OnStrategyChipClick" />
                    <ToggleButton Content="Momentum" Tag="Momentum" IsChecked="True"
                                  Style="{StaticResource ChipToggle}" Click="OnStrategyChipClick" />
                    <ToggleButton Content="События" Tag="События" IsChecked="True"
                                  Style="{StaticResource ChipToggle}" Click="OnStrategyChipClick" />
                </StackPanel>

                <!-- Поиск -->
                <TextBox Grid.Row="2" PlaceholderText="Поиск пары…" CornerRadius="16"
                         TextChanged="OnSearchTextChanged" x:Name="SearchBox" />

                <!-- Шапка таблицы -->
                <Grid Grid.Row="3" Padding="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ПАРА / СТРАТЕГИЯ" Style="{StaticResource CaptionText}" />
                    <TextBlock Grid.Column="1" Text="СКОР" Style="{StaticResource CaptionText}" />
                    <TextBlock Grid.Column="2" Text="24Ч" Style="{StaticResource CaptionText}"
                               HorizontalAlignment="Right" />
                </Grid>

                <!-- Список сигналов -->
                <ListView Grid.Row="4" x:Name="SignalsList"
                          SelectionChanged="OnSignalSelected"
                          SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="CornerRadius" Value="12" />
                            <Setter Property="Margin" Value="0,2" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SignalRow">
                            <Grid Padding="4,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="64" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{x:Bind Pair}" FontSize="13.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{x:Bind Strategy}" FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}" />
                                </StackPanel>

                                <Border Grid.Column="1" CornerRadius="13" Padding="12,4"
                                        VerticalAlignment="Center"
                                        Background="{x:Bind ScoreBackground}">
                                    <TextBlock Text="{x:Bind Score}" FontSize="12.5" FontWeight="Bold"
                                               Foreground="{x:Bind ScoreForeground}" />
                                </Border>

                                <TextBlock Grid.Column="2" Text="{x:Bind ChangeText}"
                                           FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{x:Bind ChangeBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Grid.Row="5" Text="Показаны сигналы со скорингом &gt; 40"
                           Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ================= ЦЕНТР: ГРАФИК ================= -->
        <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource GlassPanel}">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Шапка графика -->
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock x:Name="PairTitle" Text="BTC/USDT" FontSize="19" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="PairPrice" Text="—" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource UpBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="PairChange" Text="" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource UpBrush}" VerticalAlignment="Center" />

                        <!-- Поиск по ВСЕМ парам Hotcoin, не только из скринера -->
                        <AutoSuggestBox x:Name="PairSearchBox" PlaceholderText="Любая пара…"
                                        Width="170" Height="30" QueryIcon="Find"
                                        VerticalAlignment="Center"
                                        TextChanged="OnPairSearchTextChanged"
                                        QuerySubmitted="OnPairSearchSubmitted"
                                        SuggestionChosen="OnPairSearchChosen" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                        <ToggleButton Content="1м"  Tag="60"    Style="{StaticResource ChipToggle}" Click="OnTimeframeClick" />
                        <ToggleButton Content="5м"  Tag="300"   Style="{StaticResource ChipToggle}" Click="OnTimeframeClick" />
                        <ToggleButton Content="15м" Tag="900"   Style="{StaticResource ChipToggle}" Click="OnTimeframeClick" />
                        <ToggleButton Content="30м" Tag="1800"  Style="{StaticResource ChipToggle}" Click="OnTimeframeClick" />
                        <ToggleButton Content="1ч"  Tag="3600"  IsChecked="True" Style="{StaticResource ChipToggle}" Click="OnTimeframeClick" />
                        <ToggleButton Content="1Д"  Tag="86400" Style="{StaticResource ChipToggle}" Click="OnTimeframeClick" />

                        <!-- Управление индикаторами; галочки хранятся отдельно для каждой пары -->
                        <Button Content="Индикаторы ▾" CornerRadius="14" Height="30" Margin="10,0,0,0">
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <ToggleMenuFlyoutItem x:Name="IndMa10"  Text="MA (10)"   Tag="ma10|ma|{&quot;period&quot;:10}"  Click="OnIndicatorToggle" />
                                    <ToggleMenuFlyoutItem x:Name="IndMa20"  Text="MA (20)"   Tag="ma20|ma|{&quot;period&quot;:20,&quot;color&quot;:&quot;#F6C177&quot;}" Click="OnIndicatorToggle" />
                                    <ToggleMenuFlyoutItem x:Name="IndEma50" Text="EMA (50)"  Tag="ema50|ema|{&quot;period&quot;:50}" Click="OnIndicatorToggle" />
                                    <ToggleMenuFlyoutItem x:Name="IndBB"    Text="Bollinger (20, 2)" Tag="bb20|bollinger|{&quot;period&quot;:20,&quot;mult&quot;:2}" Click="OnIndicatorToggle" />
                                    <MenuFlyoutSeparator />
                                    <ToggleMenuFlyoutItem x:Name="IndRsi14" Text="RSI (14)"  Tag="rsi14|rsi|{&quot;period&quot;:14}" Click="OnIndicatorToggle" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Уровень: Ctrl+клик по графику" IsEnabled="False" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </Grid>

                <controls:TvChartControl Grid.Row="1" x:Name="Chart" />
            </Grid>
        </Border>

        <!-- ================= НИЗ ЦЕНТРА: ЛЕНТА СОБЫТИЙ ================= -->
        <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource GlassPanel}">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock Text="Лента событий" Style="{StaticResource PanelTitle}" FontSize="15" />
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                        <ToggleButton x:Name="EventsFilterToggle" IsChecked="True"
                                      Click="OnEventsFilterToggle"
                                      Content="События стратегий" FontSize="11" Padding="8,2"
                                      Foreground="{StaticResource UpBrush}"
                                      VerticalAlignment="Center" />
                        <Ellipse Width="8" Height="8" Fill="{StaticResource UpBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="live" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <ListView Grid.Row="1" x:Name="EventsList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:EventItem">
                            <Grid Padding="0,4" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Time}" FontSize="11.5"
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                                <Ellipse Grid.Column="1" Width="7" Height="7"
                                         Fill="{x:Bind TagBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Message}" FontSize="12.5"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <Border Grid.Column="3" CornerRadius="12" Padding="10,3"
                                        Background="{x:Bind TagFaintBrush}">
                                    <TextBlock Text="{x:Bind Tag}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{x:Bind TagBrush}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- ================= ПРАВАЯ КОЛОНКА ================= -->
        <ScrollViewer Grid.Column="2" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <!-- AI-анализ -->
                <Border Style="{StaticResource GlassPanel}">
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock Text="AI-анализ" Style="{StaticResource PanelTitle}" />
                            <TextBlock Text="Claude API" Style="{StaticResource CaptionText}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <Border CornerRadius="15" Padding="14,5" HorizontalAlignment="Left"
                                Background="{StaticResource UpBrush}" Opacity="0.9">
                            <TextBlock Text="LONG · Mean Rev" FontSize="12.5" FontWeight="Bold"
                                       Foreground="#0D1017" />
                        </Border>

                        <StackPanel Spacing="6">
                            <Grid>
                                <TextBlock Text="Уверенность" Style="{StaticResource CaptionText}" />
                                <TextBlock Text="72%" FontSize="12.5" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right" />
                            </Grid>
                            <ProgressBar Value="72" Maximum="100" CornerRadius="5"
                                         Foreground="{StaticResource AccentPurpleBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Причины" Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource UpBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="RSI 27 — зона перепроданности" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource UpBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Цена у нижней границы 20-дн. канала" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource UpBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Приток в BTC-ETF 5 дней подряд" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Риски" Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource DownBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="Разворот пока не подтверждён объёмом" FontSize="12"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Кнопка углублённого AI-анализа: открывает отдельное окно -->
                        <Button Content="Углублённый AI-анализ"
                                Style="{StaticResource PillAccentButton}"
                                Click="OnDeepAnalysisClick" />
                    </StackPanel>
                </Border>

                <!-- Детали пары -->
                <Border Style="{StaticResource GlassPanel}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Детали пары" Style="{StaticResource PanelTitle}" />
                        <Grid>
                            <TextBlock Text="Объём 24ч" Style="{StaticResource CaptionText}" FontSize="12.5" />
                            <TextBlock Text="$37.0 млрд" FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="Спред" Style="{StaticResource CaptionText}" FontSize="12.5" />
                            <TextBlock Text="0.02%" FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="Макс 24ч" Style="{StaticResource CaptionText}" FontSize="12.5" />
                            <TextBlock Text="64 512" FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="Мин 24ч" Style="{StaticResource CaptionText}" FontSize="12.5" />
                            <TextBlock Text="62 858" FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid>
                            <TextBlock Text="Волатильность (ATR)" Style="{StaticResource CaptionText}" FontSize="12.5" />
                            <TextBlock Text="2.8%" FontSize="12.5" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Сводка (тизер торговой вкладки) -->
        <Border Grid.Column="2" Grid.Row="1" Style="{StaticResource GlassPanel}">
            <StackPanel Spacing="10">
                <TextBlock Text="Сводка (вкладка Торговля)" FontSize="13.5" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <Grid>
                    <TextBlock Text="Баланс" Style="{StaticResource CaptionText}" FontSize="12" />
                    <TextBlock Text="$1 000.00" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" />
                </Grid>
                <Grid>
                    <TextBlock Text="Открытых сделок" Style="{StaticResource CaptionText}" FontSize="12" />
                    <TextBlock Text="0" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" />
                </Grid>
                <Grid>
                    <TextBlock Text="P&amp;L сегодня" Style="{StaticResource CaptionText}" FontSize="12" />
                    <TextBlock Text="+$0.00" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource UpBrush}" HorizontalAlignment="Right" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>
