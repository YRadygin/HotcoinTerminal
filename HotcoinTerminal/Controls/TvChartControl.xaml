<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HotcoinTerminal.Controls.TvChartControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <WebView2 x:Name="Web" DefaultBackgroundColor="Transparent" />

        <!-- Пока WebView2 инициализируется -->
