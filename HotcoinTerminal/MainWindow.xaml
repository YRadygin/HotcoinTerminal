<Window
    x:Class="HotcoinTerminal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Hotcoin Terminal">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <!-- ===== Кастомный титлбар ===== -->
        <Grid Grid.Row="0" Padding="16,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Логотип -->
            <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                    Background="{StaticResource AccentPurpleBrush}" VerticalAlignment="Center">
                <TextBlock Text="H" FontWeight="Bold" Foreground="#0D1017"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <TextBlock Grid.Column="1" Text="Hotcoin Terminal" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="12,0,24,0"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <!-- Вкладки-пилюли -->
            <ToggleButton Grid.Column="2" x:Name="AnalyticsTab" Content="Аналитика"
                          Style="{StaticResource ChipToggle}" IsChecked="True"
                          Click="OnAnalyticsTabClick" Margin="0,0,8,0" />
            <ToggleButton Grid.Column="3" x:Name="TradingTab" Content="Торговля"
                          Style="{StaticResource ChipToggle}"
                          Click="OnTradingTabClick" />

            <!-- Область перетаскивания окна -->
            <Border Grid.Column="4" x:Name="DragRegion" Background="Transparent" />

            <!-- Статус подключения (заглушка) -->
            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="0,0,160,0" Spacing="8">
                <Ellipse Width="8" Height="8" Fill="{StaticResource UpBrush}" VerticalAlignment="Center" />
                <TextBlock Text="API Hotcoin · подключено (заглушка)"
                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ===== Контент вкладок ===== -->
        <Frame Grid.Row="1" x:Name="RootFrame" Margin="12,0,12,0" />

        <!-- ===== Статус-бар ===== -->
        <Border Grid.Row="2" Margin="12,8,12,10" CornerRadius="14"
                Background="{StaticResource GlassPanelSubtleBrush}"
                BorderBrush="{StaticResource PanelStrokeBrush}" BorderThickness="1"
                Padding="18,0">
            <Grid VerticalAlignment="Center">
                <TextBlock Text="Сканирование: 128 пар · следующий цикл через 02:41 (заглушка)"
                           Style="{StaticResource CaptionText}" HorizontalAlignment="Left" />
                <TextBlock Text="Задержка API: — · WebSocket: не подключён · v0.1 (каркас)"
                           Style="{StaticResource CaptionText}" HorizontalAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</Window>
